{
  "$schema": "https://raw.githubusercontent.com/athombv/node-homey-lib/refs/heads/develop/assets/capability/schema.json",
  "type": "number",
  "title": {
    "en": "Uptime",
    "no": "Oppetid"
  },
  "desc": {
    "en": "How long the computer has been running",
    "no": "Hvor lenge datamaskinen har vært i gang"
  },
  "icon": "/assets/icons/timer.svg",
  "units": "min",
  "getable": true,
  "setable": false,
  "uiComponent": "sensor",
  "insights": true,
  "min": 0,
  "decimals": 0,
  "$flow": {
    "triggers": [
      {
        "id": "measure_uptime_changed",
        "highlight": true,
        "title": {
          "en": "The uptime changed",
          "no": "Oppetiden ble endret"
        },
        "tokens": [
          {
            "name": "measure_uptime",
            "title": {
              "en": "Minutes",
              "no": "Minutter"
            },
            "type": "number",
            "example": 10
          }
        ]
      }
    ]
  }
}
