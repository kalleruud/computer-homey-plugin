{
  "$schema": "https://raw.githubusercontent.com/athombv/node-homey-lib/refs/heads/develop/assets/capability/schema.json",
  "type": "boolean",
  "title": {
    "en": "Turned on",
    "no": "Slått på"
  },
  "desc": {
    "en": "Whether the computer is on or off",
    "no": "Om datamaskinen er på eller av"
  },
  "icon": "/assets/icons/zap.svg",
  "getable": true,
  "setable": false,
  "uiQuickAction": true,
  "insights": true,
  "insightsTitleTrue": {
    "en": "Turned on",
    "no": "Slått på"
  },
  "insightsTitleFalse": {
    "en": "Turned off",
    "no": "Slått av"
  },
  "$flow": {
    "triggers": [
      {
        "id": "onoff_true",
        "highlight": true,
        "title": {
          "en": "Turned on",
          "no": "Slått på"
        }
      },
      {
        "id": "onoff_false",
        "highlight": true,
        "title": {
          "en": "Turned off",
          "no": "Slått av"
        }
      }
    ],
    "conditions": [
      {
        "id": "on",
        "title": {
          "en": "Is turned !{{on|off}}",
          "no": "Er !{{på|av}}"
        }
      }
    ]
  }
}
