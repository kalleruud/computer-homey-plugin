{
  "extends": "@tsconfig/node16/tsconfig.json",
  "compilerOptions": {
    "allowJs": false,

    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitAny": true,

    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": false,

    "outDir": ".homeybuild/",

    "esModuleInterop": true,

    "paths": {
      "@drivers/*": ["./drivers/*"],
      "@src/*": ["./src/*"]
    }
  },
  "include": ["**/*.ts", "drivers/computer/device.mts", "drivers/computer/driver.mts", "app.mts"],
  "exclude": ["**/tests**/*"]
}
