{
  "name": "no.kallerud.computer",
  "version": "1.0.0",
  "scripts": {
    "dev": "bun gen && bunx homey app run",
    "gen": "bunx homey app build",
    "build": "tsc",
    "check": "bunx homey app validate && eslint . --cache && prettier -c . && bunx tsc --noEmit && bunx --bun knip",
    "fix": "eslint . --cache --fix && bunx --bun knip --fix --allow-remove-files && prettier -w ."
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@tsconfig/node16": "^16",
    "@types/bun": "^1",
    "@types/homey": "npm:homey-apps-sdk-v3-types@^0",
    "@types/node": "^25",
    "eslint": "^9",
    "eslint-plugin-homey-app": "^1",
    "globals": "^17",
    "homey": "^4",
    "knip": "^6",
    "prettier": "^3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^6",
    "typescript-eslint": "^8"
  },
  "prettier": {
    "arrowParens": "avoid",
    "endOfLine": "lf",
    "semi": false,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false,
    "bracketSameLine": true,
    "plugins": [
      "prettier-plugin-organize-imports"
    ]
  },
  "dependencies": {
    "@types/ssh2": "^1.15.5",
    "ssh2": "^1.17.0"
  }
}
